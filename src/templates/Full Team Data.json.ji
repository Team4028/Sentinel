                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 22,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "frameIndex": 2,
        "frozenColumns": {
          "left": 1
        },
        "showHeader": true
      },
      "pluginVersion": "12.2.1",
      "targets": [
        {
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "afh372g20yt4wd"
          },
          "hide": false,
          "queryText": "SELECT *\nFROM teams",
          "queryType": "table",
          "rawQueryText": "SELECT *\nFROM teams",
          "refId": "B",
