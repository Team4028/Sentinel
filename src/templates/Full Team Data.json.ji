        },
        {
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "afh372g20yt4wd"
          },
          "queryText": "SELECT *\r\nFROM teams_fields",
          "queryType": "table",
          "rawQueryText": "SELECT *\r\nFROM teams_fields",
          "refId": "A",
          "timeColumns": []
        }
      ],
      "title": "Team Data",
      "transformations": [
        {
          "filter": {
            "id": "byRefId",
            "options": "/^(?:A)$/"
          },
          "id": "groupingToMatrix",
          "options": {
            "columnField": "field_name",
            "rowField": "team_key",
            "valueField": "field_value"
          }
        },
        {
          "filter": {
            "id": "byRefId",
            "options": "/^(?:)$/"
          },
          "id": "renameByRegex",
          "options": {
            "regex": "^(team_key).*",
            "renamePattern": "Team"
          }
        },
        {
          "id": "joinByField",
          "options": {
            "byField": "Team",
            "mode": "inner"
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {% for header, type in team_headers %}{
                "destinationType": "{{type}}",
                "targetField": "{{header}}"
              }{% if not loop.last %},
              {% endif %}{% endfor %}
            ],
            "fields": {}
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Team"
              }
            ]
          }
        }
      ],
      "transparent": true,
      "type": "table"
    }
