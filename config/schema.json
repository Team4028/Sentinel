{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Sentinel Configuration",
    "type": "object",
    "properties": {
        "team-header-name": {
            "type": "string",
            "description": "Name of the header cooresponding to the team number"
        },
        "match-header-name": {
            "type": "string",
            "description": "Name of the header cooresponding to the match number"
        },
        "headers": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Name of the header; this will show up in the CSV and is what is used referenced in the below fields."
                    },
                    "desc": {
                        "type": "string",
                        "description": "Optional description parameter just for documentation."
                    }
                },
                "required": [
                    "name"
                ]
            }
        },
        "copr-keys": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Keys of the component opr fields to fetch"
        },
        "preproc-operations": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Name of the operation"
                    },
                    "new-headers": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "operation": {
                        "type": "string",
                        "description": "A consumer that takes in a row as a pd.Series and outputs one or more resolved series"
                    }
                },
                "required": [
                    "name",
                    "operation"
                ]
            }
        },
        "compute-fields": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Name of the field and new csv header to generate"
                    },
                    "equation": {
                        "type": "string",
                        "description": "A beakscript (lol) string defining the process to calculate this field"
                    }
                },
                "required": [
                    "name",
                    "equation"
                ]
            },
            "uniqueItems": true
        },
        "subjective-svd-fields": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Name of the output ranking header"
                    },
                    "source": {
                        "type": "string",
                        "description": "Name of source field (no '$')"
                    },
                    "compare-team-source": {
                        "type": "string",
                        "description": "Name of the field that has the team to compare to (no '$')"
                    },
                    "variance-score": {
                        "type": "null",
                        "description": "Whether to include the variance score for each team"
                    },
                    "stability": {
                        "type": "null",
                        "description": "Whether to include the stability (confidence)"
                    }
                },
                "required": ["name", "source", "compare-team-source"]
            }
        },
        "filter-unique-fields": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Fields with which to deliniate distinct rows and detect duplicates"
        },
        "team-fields": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Name of the field and csv header to generate in the teams csv"
                    },
                    "derive": {
                        "type": "string",
                        "description": "A beakscript string defining the process by which the elements of this set are obtained"
                    },
                    "avg": {
                        "type": "null",
                        "description": "Creates a field that is the average of this field"
                    },
                    "max": {
                        "type": "null",
                        "description": "Creates a field that is the max of this field"
                    },
                    "fil": {
                        "type": "null",
                        "description": "Creates a field that is the filtered average of this field"
                    }
                },
                "required": [
                    "name",
                    "derive"
                ]
            }
        },
        "match-fields": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Name of the field and csv header to generate in the teams csv"
                    },
                    "derive": {
                        "type": "string",
                        "description": "A beakscript string defining the process by which the elements of this set are obtained"
                    },
                    "static": {
                        "type": [
                            "object",
                            "null"
                        ],
                        "properties": {
                            "type": {
                                "type": "string",
                                "enum": [
                                    "list",
                                    "number"
                                ]
                            }
                        },
                        "required": [
                            "type"
                        ],
                        "description": "Derive the field via a function of the data of all teams in the match as opposed to for each team."
                    }
                },
                "required": [
                    "name",
                    "derive"
                ]
            }
        },
        "predict-metric": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "This specific name is just to be thorough and is currently hardcoded to Score for the csv"
                },
                "source": {
                    "type": "string",
                    "description": "The header (defined earlier in the YAML or in data-in) name (NOT BKSCRIPT) to pull from to calculate team score (ie. Average vs. Filtered)"
                }
            },
            "required": [
                "name",
                "source"
            ]
        },
        "depth-predict-fields": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name of this field and its output csv header"
                    },
                    "source": {
                        "type": "string",
                        "description": "The particular header name (not beakscript so no '$') from which to source this field"
                    }
                },
                "required": [
                    "name",
                    "source"
                ]
            }
        },
        "data-tests": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name of the test"
                    },
                    "expression": {
                        "type": "string",
                        "description": "a beakscript expression that evaluates to a boolean that defines filters for bad data"
                    }
                }
            }
        }
    },
    "required": [
        "team-header-name",
        "match-header-name",
        "headers",
        "compute-fields",
        "team-fields",
        "match-fields",
        "predict-metric",
        "filter-unique-fields",
        "depth-predict-fields"
    ]
}